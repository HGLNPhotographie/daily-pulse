# === Site (OAuth redirects) ==================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase (requis en production) =======================================
# Guide complet : docs/SUPABASE_SETUP.md
# Auth Phase 2 (email, Google, Apple) : docs/AUTH_SETUP.md
#
# Project Settings → API dans le dashboard Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role — SERVEUR UNIQUEMENT (routes API, cron, vérif admin).
# Ne jamais préfixer par NEXT_PUBLIC_ ni committer cette valeur.
SUPABASE_SERVICE_ROLE_KEY=

# === Dashboard Supabase à activer manuellement =============================
# - Authentication → Providers → Anonymous Sign-Ins : ON (votants sans compte)
# - Créer un user email/password puis :
#   update public.users set is_admin = true where email = 'toi@exemple.com';

# === Web Push (VAPID) — optionnel ==========================================
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Secret pour /api/cron/notify (scheduler Vercel / cron externe)
CRON_SECRET=

# === Capacitor (apps natives) ================================================
# URL de l'app déployée (Vercel) pour les builds iOS/Android
# CAPACITOR_SERVER_URL=https://ton-app.vercel.app
