# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS / volumes externes (fichiers AppleDouble sur exFAT)
.DS_Store
._*

# Capacitor (iOS / Android) — les projets natifs sont versionnés, pas leurs
# artefacts de build ni les dépendances générées.
ios/App/Pods
ios/App/Podfile.lock
ios/App/build
ios/App/DerivedData
ios/**/xcuserdata
android/app/build
android/build
android/.gradle
android/local.properties
android/captures
android/.idea
*.keystore
*.jks
